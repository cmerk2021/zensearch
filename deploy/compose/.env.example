# Zen environment configuration (Layer 1 — infrastructure only).
# Copy to .env next to your docker-compose.yml and edit.

# REQUIRED — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# or: openssl rand -base64 48
ZEN_SECRET_KEY=

# REQUIRED for the full compose file.
POSTGRES_PASSWORD=

# Public URL of your instance (needed for OIDC redirects and absolute links).
# Example: https://zen.example.com
ZEN_BASE_URL=

# Host port the web UI listens on.
ZEN_HTTP_PORT=3000

# Comma-separated proxy IPs/CIDRs whose X-Forwarded-For is trusted.
# Set this when running behind Traefik/Nginx/Caddy, e.g. 172.16.0.0/12
ZEN_TRUSTED_PROXIES=
